# Copy to `.env.local` for local development (never commit real values).
# Restart `npm start` after changing env vars.
#
# Netlify / CI: add the same REACT_APP_* keys under Site configuration → Environment
# variables (same names as below). Redeploy after saving—Create React App inlines
# them at build time; .env.local is not used on the server.
#
# EmailJS: https://www.emailjs.com/docs/ (use the public key as REACT_APP_EMAILJS_USER_ID)
#
# Free plan: domain whitelist is not available (Personal+ only). You do not add localhost
# there on free—use the public key from the browser as this app does.
#
# Account → Security → API Settings: if "Use Private Key" is ON, browser-only sends will
# fail unless you add a serverless endpoint that calls EmailJS with the private key
# (accessToken). For this client-only setup, turn OFF "Use Private Key".
#
# Personal+ with whitelist enabled: add exact origins (scheme + host + port), e.g.
# http://localhost:3000 and http://127.0.0.1:3000.
REACT_APP_EMAILJS_SERVICE_ID=
REACT_APP_EMAILJS_TEMPLATE_ID=
REACT_APP_EMAILJS_USER_ID=
#
# Google reCAPTCHA v2 "I'm not a robot" checkbox key (public site key only).
# In https://www.google.com/recaptcha/admin add domains: localhost, 127.0.0.1,
# and your production host (e.g. thatdeveloper.dev and www).
REACT_APP_RECAPTCHA_SITE_KEY=
